# DB
DATABASE_URL=mysql+aiomysql://root:password@localhost:3306/saemaul

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=your-secret-key-change-this
JWT_ACCESS_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_DAYS=7

# 토스페이먼츠
TOSS_SECRET_KEY=test_sk_xxxxx
TOSS_CLIENT_KEY=test_ck_xxxxx

# AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=saemaul-bucket
AWS_REGION=ap-northeast-2

# FCM
FCM_CREDENTIALS_PATH=firebase-credentials.json

# 환경
ENVIRONMENT=development
DEBUG=true
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:19000
